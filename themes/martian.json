{
  "name": "Martian",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "foreground": "#e0d8d0",
    "focusBorder": "#FF6B0044",
    "widget.shadow": "#00000070",
    "selection.background": "#FF6B0030",
    "descriptionForeground": "#6a5a48",
    "errorForeground": "#E53E3E",

    "titleBar.activeBackground": "#0a0804",
    "titleBar.activeForeground": "#FF6B00",
    "titleBar.inactiveBackground": "#0a0804",
    "titleBar.inactiveForeground": "#4a3e30",

    "activityBar.background": "#0a0804",
    "activityBar.foreground": "#FF6B00",
    "activityBar.inactiveForeground": "#4a3e30",
    "activityBar.border": "#141008",
    "activityBarBadge.background": "#8B5CF6",
    "activityBarBadge.foreground": "#ffffff",

    "sideBar.background": "#0c0a06",
    "sideBar.foreground": "#e0d8d0",
    "sideBar.border": "#141008",
    "sideBarTitle.foreground": "#FF6B00",
    "sideBarSectionHeader.background": "#100c06",
    "sideBarSectionHeader.foreground": "#6a5a48",

    "editor.background": "#0b0906",
    "editor.foreground": "#e0d8d0",
    "editor.lineHighlightBackground": "#14100840",
    "editor.selectionBackground": "#FF6B0025",
    "editor.inactiveSelectionBackground": "#FF6B0012",
    "editor.findMatchBackground": "#42f4c830",
    "editor.findMatchHighlightBackground": "#42f4c818",
    "editor.wordHighlightBackground": "#8B5CF618",
    "editorCursor.foreground": "#FF6B00",
    "editorWhitespace.foreground": "#1a1410",
    "editorIndentGuide.background1": "#161008",
    "editorIndentGuide.activeBackground1": "#2a1e10",
    "editorLineNumber.foreground": "#2a2018",
    "editorLineNumber.activeForeground": "#FF6B0088",
    "editorBracketMatch.background": "#8B5CF618",
    "editorBracketMatch.border": "#8B5CF644",
    "editorGutter.addedBackground": "#42f4c866",
    "editorGutter.modifiedBackground": "#8B5CF666",
    "editorGutter.deletedBackground": "#E53E3E66",
    "editorOverviewRuler.border": "#141008",

    "editorGroupHeader.tabsBackground": "#0a0804",
    "editorGroupHeader.tabsBorder": "#141008",
    "tab.activeBackground": "#120e06",
    "tab.activeForeground": "#f0e8e0",
    "tab.activeBorderTop": "#FF6B00",
    "tab.inactiveBackground": "#0a0804",
    "tab.inactiveForeground": "#4a3e30",
    "tab.border": "#141008",
    "tab.hoverBackground": "#14100a",

    "list.activeSelectionBackground": "#FF6B0018",
    "list.activeSelectionForeground": "#f0e8e0",
    "list.inactiveSelectionBackground": "#FF6B000c",
    "list.hoverBackground": "#100c08",
    "list.focusBackground": "#FF6B0015",
    "list.highlightForeground": "#FF6B00",

    "statusBar.background": "#0a0804",
    "statusBar.foreground": "#FF6B00aa",
    "statusBar.border": "#141008",
    "statusBar.debuggingBackground": "#E53E3E",
    "statusBar.debuggingForeground": "#ffffff",
    "statusBar.noFolderBackground": "#0a0804",
    "statusBarItem.hoverBackground": "#FF6B0018",
    "statusBarItem.remoteBackground": "#8B5CF6",
    "statusBarItem.remoteForeground": "#ffffff",

    "panel.background": "#0b0906",
    "panel.border": "#1a1410",
    "panelTitle.activeBorder": "#FF6B00",
    "panelTitle.activeForeground": "#e0d8d0",
    "panelTitle.inactiveForeground": "#4a3e30",

    "terminal.background": "#0a0804",
    "terminal.foreground": "#e0d8d0",
    "terminal.ansiBlack": "#1a1410",
    "terminal.ansiRed": "#E53E3E",
    "terminal.ansiGreen": "#42f4c8",
    "terminal.ansiYellow": "#F6AD55",
    "terminal.ansiBlue": "#63B3ED",
    "terminal.ansiMagenta": "#8B5CF6",
    "terminal.ansiCyan": "#42f4c8",
    "terminal.ansiWhite": "#e0d8d0",
    "terminal.ansiBrightBlack": "#3a3028",
    "terminal.ansiBrightRed": "#ff5c5c",
    "terminal.ansiBrightGreen": "#6afce0",
    "terminal.ansiBrightYellow": "#ffc878",
    "terminal.ansiBrightBlue": "#88ccff",
    "terminal.ansiBrightMagenta": "#A855F7",
    "terminal.ansiBrightCyan": "#6afce0",
    "terminal.ansiBrightWhite": "#f0e8e0",
    "terminalCursor.foreground": "#FF6B00",

    "input.background": "#100c06",
    "input.foreground": "#e0d8d0",
    "input.border": "#201810",
    "input.placeholderForeground": "#4a3e30",
    "inputOption.activeBorder": "#FF6B00",

    "dropdown.background": "#100c06",
    "dropdown.foreground": "#e0d8d0",
    "dropdown.border": "#201810",

    "button.background": "#FF6B00",
    "button.foreground": "#0a0804",
    "button.hoverBackground": "#FF7F32",
    "button.secondaryBackground": "#201810",
    "button.secondaryForeground": "#e0d8d0",

    "badge.background": "#8B5CF6",
    "badge.foreground": "#ffffff",

    "scrollbar.shadow": "#00000060",
    "scrollbarSlider.background": "#FF6B0015",
    "scrollbarSlider.hoverBackground": "#FF6B0028",
    "scrollbarSlider.activeBackground": "#FF6B003c",

    "breadcrumb.foreground": "#4a3e30",
    "breadcrumb.focusForeground": "#e0d8d0",
    "breadcrumb.activeSelectionForeground": "#FF6B00",
    "breadcrumbPicker.background": "#100c06",

    "gitDecoration.addedResourceForeground": "#42f4c8",
    "gitDecoration.modifiedResourceForeground": "#FF6B00",
    "gitDecoration.deletedResourceForeground": "#E53E3E",
    "gitDecoration.untrackedResourceForeground": "#63B3ED",
    "gitDecoration.ignoredResourceForeground": "#2a2018",
    "gitDecoration.conflictingResourceForeground": "#F6AD55",

    "minimap.selectionHighlight": "#FF6B0030",
    "minimap.findMatchHighlight": "#42f4c840",

    "peekView.border": "#8B5CF644",
    "peekViewEditor.background": "#0c0a06",
    "peekViewResult.background": "#0c0a06",
    "peekViewTitle.background": "#100c06",

    "notifications.background": "#100c06",
    "notifications.foreground": "#e0d8d0",
    "notifications.border": "#201810"
  },
  "semanticTokenColors": {
    "function.declaration": "#63B3ED",
    "function.defaultLibrary": "#42f4c8aa",
    "variable.readonly": "#e0c8a0",
    "variable.defaultLibrary": "#F6AD55",
    "property.readonly": "#a09080",
    "type.defaultLibrary": "#F6AD55",
    "class": "#8B5CF6",
    "interface": "#42f4c8",
    "enum": "#8B5CF6",
    "enumMember": "#FF4500",
    "namespace": "#FF6B00",
    "decorator": "#F6AD55",
    "parameter.declaration": "#A855F7",
    "typeParameter": "#42f4c8",
    "*.modification": { "fontStyle": "underline" },
    "*.async": { "fontStyle": "italic" },
    "variable.readonly.defaultLibrary": "#F6AD55"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#3a3028", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#42f4c8" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#F6AD55" } },
    { "scope": ["constant.language", "constant.other"], "settings": { "foreground": "#FF4500" } },
    { "scope": ["keyword", "storage.type", "storage.modifier"], "settings": { "foreground": "#FF6B00" } },
    { "scope": ["keyword.control", "keyword.operator.logical"], "settings": { "foreground": "#FF7F32" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#a09080" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#63B3ED" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.class", "support.type"], "settings": { "foreground": "#8B5CF6" } },
    { "scope": ["entity.name.type.interface"], "settings": { "foreground": "#42f4c8" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#e0d8d0" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#A855F7" } },
    { "scope": ["variable.other.property", "variable.other.object.property"], "settings": { "foreground": "#a09080" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#FF6B00" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#8B5CF6", "fontStyle": "italic" } },
    { "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"], "settings": { "foreground": "#42f4c8" } },
    { "scope": ["support.type.property-name.css"], "settings": { "foreground": "#63B3ED" } },
    { "scope": ["variable.scss", "variable.css"], "settings": { "foreground": "#A855F7" } },
    { "scope": ["string.regexp"], "settings": { "foreground": "#E53E3E" } },
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#42f4c8" } },
    { "scope": ["punctuation"], "settings": { "foreground": "#5a4a38" } },
    { "scope": ["support.type.property-name.json"], "settings": { "foreground": "#a09080" } },
    { "scope": ["markup.heading", "entity.name.section.markdown"], "settings": { "foreground": "#FF6B00", "fontStyle": "bold" } },
    { "scope": ["markup.bold"], "settings": { "foreground": "#f0e8e0", "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "foreground": "#A855F7", "fontStyle": "italic" } },
    { "scope": ["markup.underline.link"], "settings": { "foreground": "#63B3ED" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code"], "settings": { "foreground": "#42f4c8" } },
    { "scope": ["punctuation.section.embedded.begin.php", "punctuation.section.embedded.end.php"], "settings": { "foreground": "#FF6B00" } },
    { "scope": ["variable.other.php"], "settings": { "foreground": "#A855F7" } },
    { "scope": ["entity.name.tag.yaml"], "settings": { "foreground": "#a09080" } },
    { "scope": ["variable.language.this", "variable.language.self"], "settings": { "foreground": "#FF4500", "fontStyle": "italic" } }
  ]
}