    "terminal.ansiGreen": "#68c030",
    "terminal.ansiYellow": "#c8a830",
    "terminal.ansiBlue": "#5888b0",
    "terminal.ansiMagenta": "#9868a8",
    "terminal.ansiCyan": "#48a8a0",
    "terminal.ansiWhite": "#c0d0b8",
