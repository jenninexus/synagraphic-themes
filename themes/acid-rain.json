    "button.secondaryForeground": "#c0d0b8",

    "badge.background": "#68c030",
    "badge.foreground": "#040806",

    "scrollbar.shadow": "#00000040",
    "scrollbarSlider.background": "#68c03018",
    "scrollbarSlider.hoverBackground": "#68c03030",
    "scrollbarSlider.activeBackground": "#68c03044",

    "breadcrumb.foreground": "#405838",
    "breadcrumb.focusForeground": "#c0d0b8",
    "breadcrumb.activeSelectionForeground": "#68c030",
    "breadcrumbPicker.background": "#080e0a",

    "gitDecoration.addedResourceForeground": "#68c030",
    "gitDecoration.modifiedResourceForeground": "#c8a830",
    "gitDecoration.deletedResourceForeground": "#d85040",
    "gitDecoration.untrackedResourceForeground": "#48a8a0",
    "gitDecoration.ignoredResourceForeground": "#1e301e",
    "gitDecoration.conflictingResourceForeground": "#c8a830",

    "minimap.selectionHighlight": "#68c03044",
    "minimap.findMatchHighlight": "#90e84844",

    "peekView.border": "#68c03044",
    "peekViewEditor.background": "#060a08",
    "peekViewResult.background": "#060a08",
    "peekViewTitle.background": "#080e0a",

    "notifications.background": "#080e0a",
    "notifications.foreground": "#c0d0b8",
    "notifications.border": "#101c10"
  },
  "semanticTokenColors": {
    "function.declaration": "#5888b0",
    "function.defaultLibrary": "#88a078",
    "variable.readonly": "#a0b890",
    "variable.defaultLibrary": "#c8a830",
    "property.readonly": "#88a078",
    "type.defaultLibrary": "#c8a830",
    "class": "#c8a830",
    "interface": "#48a8a0",
    "enum": "#c8a830",
    "enumMember": "#d85040",
    "namespace": "#68c030",
    "decorator": "#c8a830",
    "parameter.declaration": "#a0b890",
    "typeParameter": "#48a8a0",
    "*.modification": { "fontStyle": "underline" },
    "*.async": { "fontStyle": "italic" },
    "variable.readonly.defaultLibrary": "#c8a830"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#2e4028", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#90e848" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#c8a830" } },
    { "scope": ["constant.language", "constant.other"], "settings": { "foreground": "#d85040" } },
    { "scope": ["keyword", "storage.type", "storage.modifier"], "settings": { "foreground": "#68c030" } },
    { "scope": ["keyword.control", "keyword.operator.logical"], "settings": { "foreground": "#80d848" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#48a8a0" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#5888b0" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.class", "support.type"], "settings": { "foreground": "#c8a830" } },
    { "scope": ["entity.name.type.interface"], "settings": { "foreground": "#48a8a0" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#c0d0b8" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#a0b890" } },
    { "scope": ["variable.other.property", "variable.other.object.property"], "settings": { "foreground": "#88a078" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#68c030" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#48a8a0", "fontStyle": "italic" } },
    { "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"], "settings": { "foreground": "#90e848" } },
    { "scope": ["support.type.property-name.css"], "settings": { "foreground": "#88a078" } },
    { "scope": ["variable.scss", "variable.css"], "settings": { "foreground": "#a0b890" } },
    { "scope": ["string.regexp"], "settings": { "foreground": "#d85040" } },
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#48a8a0" } },
    { "scope": ["punctuation"], "settings": { "foreground": "#4a6040" } },
    { "scope": ["support.type.property-name.json"], "settings": { "foreground": "#88a078" } },
    { "scope": ["markup.heading", "entity.name.section.markdown"], "settings": { "foreground": "#68c030", "fontStyle": "bold" } },
    { "scope": ["markup.bold"], "settings": { "foreground": "#d0e0c8", "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "foreground": "#a0b890", "fontStyle": "italic" } },
    { "scope": ["markup.underline.link"], "settings": { "foreground": "#48a8a0" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code"], "settings": { "foreground": "#90e848" } },
    { "scope": ["punctuation.section.embedded.begin.php", "punctuation.section.embedded.end.php"], "settings": { "foreground": "#d85040" } },
    { "scope": ["variable.other.php"], "settings": { "foreground": "#a0b890" } },
    { "scope": ["entity.name.tag.yaml"], "settings": { "foreground": "#88a078" } },
    { "scope": ["variable.language.this", "variable.language.self"], "settings": { "foreground": "#9868a8", "fontStyle": "italic" } }
  ]
}
