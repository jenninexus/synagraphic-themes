    "notifications.background": "#080c14",
    "notifications.foreground": "#b8c4d8",
    "notifications.border": "#141c30"
  },
  "semanticTokenColors": {
    "function.declaration": "#5c8aff",
    "function.defaultLibrary": "#42f4c8aa",
    "variable.readonly": "#c0d0e8",
    "variable.defaultLibrary": "#f0e050",
    "property.readonly": "#8090b0",
    "type.defaultLibrary": "#f0e050",
    "class": "#b48eff",
    "interface": "#42f4c8",
    "enum": "#b48eff",
    "enumMember": "#ff6e9c",
    "namespace": "#42f4c8",
    "decorator": "#f0e050",
    "parameter.declaration": "#d0a0ff",
    "typeParameter": "#42f4c8",
    "*.modification": { "fontStyle": "underline" },
    "*.async": { "fontStyle": "italic" },
    "variable.readonly.defaultLibrary": "#f0e050"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#2a3650", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#42f4c8" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#f0e050" } },
    { "scope": ["constant.language", "constant.other"], "settings": { "foreground": "#ff6e9c" } },
    { "scope": ["keyword", "storage.type", "storage.modifier"], "settings": { "foreground": "#ff2d6f" } },
    { "scope": ["keyword.control", "keyword.operator.logical"], "settings": { "foreground": "#ff5c80" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#8090b0" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#5c8aff" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.class", "support.type"], "settings": { "foreground": "#b48eff" } },
    { "scope": ["entity.name.type.interface"], "settings": { "foreground": "#42f4c8" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#b8c4d8" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#d0a0ff" } },
    { "scope": ["variable.other.property", "variable.other.object.property"], "settings": { "foreground": "#8090b0" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#ff2d6f" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#b48eff", "fontStyle": "italic" } },
    { "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"], "settings": { "foreground": "#42f4c8" } },
    { "scope": ["support.type.property-name.css"], "settings": { "foreground": "#5c8aff" } },
    { "scope": ["variable.scss", "variable.css"], "settings": { "foreground": "#d0a0ff" } },
    { "scope": ["string.regexp"], "settings": { "foreground": "#ff3860" } },
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#42f4c8" } },
    { "scope": ["punctuation"], "settings": { "foreground": "#3a5070" } },
    { "scope": ["support.type.property-name.json"], "settings": { "foreground": "#8090b0" } },
    { "scope": ["markup.heading", "entity.name.section.markdown"], "settings": { "foreground": "#42f4c8", "fontStyle": "bold" } },
    { "scope": ["markup.bold"], "settings": { "foreground": "#e0e8f0", "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "foreground": "#d0a0ff", "fontStyle": "italic" } },
    { "scope": ["markup.underline.link"], "settings": { "foreground": "#5c8aff" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code"], "settings": { "foreground": "#42f4c8" } },
    { "scope": ["punctuation.section.embedded.begin.php", "punctuation.section.embedded.end.php"], "settings": { "foreground": "#ff2d6f" } },
    { "scope": ["variable.other.php"], "settings": { "foreground": "#d0a0ff" } },
    { "scope": ["entity.name.tag.yaml"], "settings": { "foreground": "#8090b0" } },
    { "scope": ["variable.language.this", "variable.language.self"], "settings": { "foreground": "#ff6e9c", "fontStyle": "italic" } }
  ]
}
